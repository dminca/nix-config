# Put these as encrypted lines under key oauth2_proxy_env in your SOPS file.
# Example SOPS string value format:
# oauth2_proxy_env: |
#   OAUTH2_PROXY_CLIENT_SECRET=<keycloak-client-secret>
#   OAUTH2_PROXY_COOKIE_SECRET=<32-byte-base64>

OAUTH2_PROXY_CLIENT_SECRET=replace-with-keycloak-client-secret
OAUTH2_PROXY_COOKIE_SECRET=replace-with-32-byte-base64
